PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_CONTROLLER_HOST=https://your-controller.pinecone.io
MISTRAL_API_KEY=your_mistral_api_key_here

# Optional - will create 'ai-knowledge-assistant' if unset
PINECONE_INDEX_NAME=ai-knowledge-assistant

# Defaults
PINECONE_DIMENSION=1536
PINECONE_METRIC=cosine
PINECONE_SERVERLESS_CLOUD=aws
PINECONE_SERVERLESS_REGION=us-east-1
PINECONE_NAMESPACE=
MISTRAL_CHAT_MODEL=mistral-small
MISTRAL_EMBED_MODEL=mistral-embed
PORT=4000
